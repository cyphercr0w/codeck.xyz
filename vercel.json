{
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "X-Content-Type-Options", "value": "nosniff" },
				{ "key": "X-Frame-Options", "value": "DENY" },
				{ "key": "X-XSS-Protection", "value": "1; mode=block" },
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(), geolocation=()"
				}
			]
		},
		{
			"source": "/assets/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*\\.(?:svg|png|ico|webp|jpg|jpeg|gif|woff2?))",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/install",
			"destination": "https://raw.githubusercontent.com/cyphercr0w/codeck/main/scripts/install.sh"
		},
		{
			"source": "/install.ps1",
			"destination": "https://raw.githubusercontent.com/cyphercr0w/codeck/main/scripts/install.ps1"
		}
	]
}
